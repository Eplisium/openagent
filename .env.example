# OpenRouter API Configuration
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_api_key_here

# Optional: App Attribution (for OpenRouter rankings)
SITE_URL=https://localhost
SITE_NAME=OpenRouter Master Script

# Model Selection
# Models are now selected dynamically via the ModelBrowser
# No hardcoded defaults - user picks from OpenRouter API

# Advanced Settings
MAX_RETRIES=3
TIMEOUT_MS=300000
STREAMING_ENABLED=true

# Cost Control
MAX_COST_PER_REQUEST_USD=0.50
BUDGET_WARNING_THRESHOLD=10.00