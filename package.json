{
  "name": "openagent",
  "version": "0.1.20",
  "description": "🚀 OpenAgent v0.1.20 - Production-grade AI agent with 400+ models, cross-platform support, and skills marketplace.",
  "main": "src/index.js",
  "type": "module",
  "bin": {
    "openagent": "src/cli.js",
    "oagent": "src/cli.js"
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "exports": {
    ".": {
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./agent": {
      "import": "./src/agent/Agent.js",
      "default": "./src/agent/Agent.js"
    },
    "./tools": {
      "import": "./src/tools/index.js",
      "default": "./src/tools/index.js"
    },
    "./config": {
      "import": "./src/config.js",
      "default": "./src/config.js"
    },
    "./errors": {
      "import": "./src/errors.js",
      "default": "./src/errors.js"
    }
  },
  "scripts": {
    "start": "node src/cli.js",
    "cli": "node src/cli.js",
    "demo": "node examples/demo.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "streaming": "node examples/streaming-demo.js",
    "tools": "node examples/tool-calling-demo.js",
    "agents": "node examples/agents-demo.js",
    "skills": "node src/cli/skills-commands.js"
  },
  "keywords": [
    "openagent",
    "openrouter",
    "ai",
    "llm",
    "agent",
    "agentic",
    "coding",
    "assistant",
    "cli",
    "cross-platform",
    "skills",
    "plugins"
  ],
  "author": "Zach",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@hono/node-server": "^1.13.8",
    "@inquirer/prompts": "^7.3.3",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "cli-spinners": "^3.4.0",
    "cli-table3": "^0.6.5",
    "cross-spawn": "^7.0.3",
    "detect-indent": "^7.0.0",
    "dotenv": "^16.4.7",
    "figlet": "^1.11.0",
    "glob": "^10.4.5",
    "gradient-string": "^3.0.0",
    "hono": "^4.7.4",
    "inquirer": "^12.3.0",
    "is-docker": "^3.0.0",
    "is-wsl": "^3.0.0",
    "listr2": "^10.2.1",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "nanospinner": "^1.2.2",
    "ora": "^8.1.2",
    "picocolors": "^0.2.1",
    "undici": "^7.24.5",
    "which": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "eslint": "^9.39.4",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
