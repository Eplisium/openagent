{
  "name": "openagent",
  "version": "4.0.0",
  "description": "🚀 OpenAgent v4.0 - Production-grade AI agent with 400+ models. Native fetch (zero axios), AbortController, request deduplication, real cost tracking, and 2026 performance optimizations. On par with Claude Code, Cursor, and Codex.",
  "main": "src/index.js",
  "type": "module",
  "bin": {
    "openagent": "src/cli.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "cli": "node src/cli.js",
    "demo": "node examples/demo.js",
    "test": "node tests/test-suite.js",
    "test:regressions": "node tests/cli-regressions.js",
    "streaming": "node examples/streaming-demo.js",
    "tools": "node examples/tool-calling-demo.js",
    "vision": "node examples/vision-demo.js",
    "agents": "node examples/agents-demo.js",
    "agent": "node examples/agent-demo.js",
    "subagents": "node examples/subagent-demo.js",
    "quick": "node -e \"import('./src/index.js').then(m => m.quickRun(process.argv.slice(1).join(' ')))\"",
    "quick-chat": "node -e \"import('./src/index.js').then(m => m.quickChat(process.argv.slice(1).join(' '))).then(r => console.log(r.content))\""
  },
  "keywords": [
    "openagent",
    "openrouter",
    "ai",
    "llm",
    "agent",
    "agentic",
    "coding",
    "assistant",
    "gpt-5",
    "claude",
    "gemini",
    "streaming",
    "tool-calling",
    "cli",
    "2026"
  ],
  "author": "Zach",
  "license": "MIT",
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "dotenv": "^16.4.7",
    "fs-extra": "^11.3.0",
    "glob": "^10.4.5",
    "gradient-string": "^3.0.0",
    "inquirer": "^12.3.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "ora": "^8.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
