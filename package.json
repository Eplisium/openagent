{
  "name": "openagent",
  "version": "4.2.0",
  "description": "🚀 OpenAgent v4.2 - Production-grade AI agent with 400+ models, modern Ink UI, cross-platform support, and skills marketplace.",
  "main": "src/index.js",
  "type": "module",
  "bin": {
    "openagent": "src/cli.js",
    "oagent": "src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "ui": "node src/cli.js --ui",
    "start:ui": "node dist/cli-ink.mjs",
    "cli": "node src/cli.js",
    "demo": "node examples/demo.js",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:ui": "vitest run tests/ui/",
    "build": "node esbuild.config.mjs",
    "build:full": "npm run build && npm test",
    "dev:ui": "tsx src/cli-ink.js",
    "streaming": "node examples/streaming-demo.js",
    "tools": "node examples/tool-calling-demo.js",
    "agents": "node examples/agents-demo.js",
    "skills": "node src/cli/skills-commands.js"
  },
  "keywords": [
    "openagent",
    "openrouter",
    "ai",
    "llm",
    "agent",
    "agentic",
    "coding",
    "assistant",
    "cli",
    "ink",
    "react",
    "cross-platform",
    "skills",
    "plugins"
  ],
  "author": "Zach",
  "license": "MIT",
  "dependencies": {
    "@inkjs/ui": "^1.0.0",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "cross-spawn": "^7.0.3",
    "detect-indent": "^7.0.0",
    "dotenv": "^16.4.7",
    "esbuild": "^0.25.0",
    "fs-extra": "^11.3.0",
    "glob": "^10.4.5",
    "gradient-string": "^3.0.0",
    "inquirer": "^12.3.0",
    "ink": "^4.4.1",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "ink-link": "^4.0.0",
    "ink-markdown": "^1.0.0",
    "ink-select-input": "^5.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^5.0.1",
    "is-docker": "^3.0.0",
    "is-wsl": "^3.0.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "ora": "^8.1.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "undici": "^7.24.5",
    "which": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@vitejs/plugin-react": "^4.3.4",
    "ink-testing-library": "^3.0.0",
    "tsx": "^4.19.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
